# Copy this file to .env and fill in real values. .env is gitignored.
#
#   cp .env.example .env
#   # fill in values
#   source .env
#   .venv/bin/python3 tools/line_webhook.py

# ── LINE Messaging API ──────────────────────────────────────────────────────
# From: https://developers.line.biz → your channel → Messaging API
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
OWNER_LINE_USER_ID=your-line-user-id

# ── LLM provider ────────────────────────────────────────────────────────────
# Which provider coach_reply / daily_push use. `claude` | `gemini`
LLM_PROVIDER=claude

# Anthropic (direct API — used when USE_BEDROCK=false)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Bedrock (optional — when USE_BEDROCK=true, uses AWS Bedrock + boto3)
USE_BEDROCK=false
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_ID=gemini-2.0-flash

# ── GCS ─────────────────────────────────────────────────────────────────────
GCS_PROFILES_BUCKET=capybara-profiles
GOOGLE_CLOUD_PROJECT=hanana-491223

# ── Daily push ──────────────────────────────────────────────────────────────
# Bearer token for POST /trigger/daily_push. Generate with: openssl rand -hex 32
DAILY_PUSH_SECRET=your-daily-push-bearer-secret

# ── Runtime ─────────────────────────────────────────────────────────────────
PORT=8080
